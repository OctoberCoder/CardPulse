# Database (local dev)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cardpulse
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/cardpulse

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption
ENCRYPTION_KEY=change-me-in-production-32bytes!

# Rate Limiting
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_GENERAL=30/minute
RATE_LIMIT_BROWSE=100/minute

# Monitoring
SENTRY_DSN=
LOGTAIL_TOKEN=

# Reloadly API
RELOADLY_CLIENT_ID=
RELOADLY_CLIENT_SECRET=
RELOADLY_ENVIRONMENT=sandbox

# Payments
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=
